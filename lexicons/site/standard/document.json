{
  "lexicon": 1,
  "id": "site.standard.document",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["title", "publishedAt"],
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "publishedAt": { "type": "string", "format": "datetime" },
          "path": { "type": "string" },
          "site": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "content": { "type": "unknown" },
          "coverImage": { "type": "blob" }
        }
      }
    }
  }
}
